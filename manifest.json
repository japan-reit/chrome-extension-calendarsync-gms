{
  "manifest_version": 3,
  "name": "Eco Calendar Syncer",
  "version": "1.0.0",
  "description": "GoogleとOutlookカレンダーを簡単に双方向同期します。",
  "permissions": [
    "identity",
    "storage",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "oauth2": {
    "client_id": "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.events"
    ]
  }
}
