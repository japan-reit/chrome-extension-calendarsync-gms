{
  "manifest_version": 3,
  "name": "GMS Calendar Sync",
  "version": "1.0.0",
  "description": "GoogleとOutlookカレンダーを簡単に双方向同期します。",
  "permissions": [
    "identity",
    "storage",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "oauth2": {                                                                                                                                         
    "client_id": "905591288296-4pe2iqqm09cimodbov89s3u5v00phfu5.apps.googleusercontent.com",                                                                                       
    "scopes": [                                                                                                                                       
      "https://www.googleapis.com/auth/calendar.events"                                                                                               
    ]                                                                                                                                               
  }     
}
